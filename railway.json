{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "preDeployCommand": "python manage.py collectstatic --noinput && python manage.py migrate --noinput",
    "startCommand": "gunicorn Project.wsgi:application --bind 0.0.0.0:$PORT --workers 1 --threads 2 --timeout 120 --max-requests 200 --max-requests-jitter 25",
    "healthcheckPath": "/live/",
    "healthcheckPort": "$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
