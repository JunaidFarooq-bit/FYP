# ============================================================
# WebLift SEO Platform - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values
# Never commit .env file to version control!

# ============================================================
# 🔐 Django Core Configuration
# ============================================================

# Django Secret Key (REQUIRED)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here

# Debug Mode (development: true, production: false)
DEBUG=false

# Allowed Hosts (comma-separated)
# For production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF Trusted Origins (comma-separated, for production)
# Example: https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=

# ============================================================
# 🗄️ Database Configuration
# ============================================================

# Database Type (true=SQLite, false=PostgreSQL)
# SQLite: Good for development, works with Pinecone
# PostgreSQL: Required for pgvector vector storage
USE_SQLITE=true

# PostgreSQL Configuration (only if USE_SQLITE=false)
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-postgres-password
# DB_HOST=localhost
# DB_PORT=5432

# ============================================================
# 🚀 Performance & Caching
# ============================================================

# Redis Caching (true=enabled, false=disabled)
# Requires Redis server running
USE_REDIS_CACHE=false

# S3 Storage for static files (production only)
USE_S3=false
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-east-1




# Groq Configuration (free, OpenAI-compatible)
USE_GROQ=true
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================
# 🔍 SEO & Analytics APIs
# ============================================================

# Moz API Configuration (optional)
USE_MOZ_API=false
MOZ_ACCESS_ID=your-moz-access-id
MOZ_SECRET_KEY=your-moz-secret-key
MOZ_API_MONTHLY_LIMIT=50

# Google PageSpeed Insights API (optional)
PAGESPEED_API_KEY=your-pagespeed-api-key

# ============================================================
# � Keyword Data Providers (for REAL search volume, KD, CPC)
# ============================================================
# Without these, all keyword metrics are estimated from heuristics.
# Priority order: SEMrush > DataForSEO > Serpstat > estimation fallback

# --- DataForSEO (RECOMMENDED — pay-as-you-go, ~$0.0015/keyword) ---
# Sign up: https://dataforseo.com → API Access → copy login + password
# Also provides live SERP data for real SGE/AI Overview detection
DATAFORSEO_LOGIN=your-dataforseo-email
DATAFORSEO_PASSWORD=your-dataforseo-password

# --- SEMrush (most comprehensive, requires paid plan ~$130/mo) ---
# Sign up: https://semrush.com → Account → API → copy key
SEMRUSH_API_KEY=your-semrush-api-key

# --- Serpstat (affordable alternative, ~$50/mo) ---
# Sign up: https://serpstat.com → Profile → API → copy key
SERPSTAT_API_KEY=your-serpstat-api-key

# --- SerpAPI (for live SERP + real SGE/AI Overview detection) ---
# Sign up: https://serpapi.com → Dashboard → copy API key
# Used by SERP feature predictor to detect real featured snippets
SERPAPI_KEY=your-serpapi-key

# --- Google Search Console API (FREE — real CTR for YOUR site) ---
# Setup: https://search.google.com/search-console/api/reference
# Gives real CTR, impressions, position data for pages you own
GOOGLE_SEARCH_CONSOLE_JSON=/path/to/service-account.json
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://yourdomain.com

# ============================================================
# �📦 Vector Database Configuration
# ============================================================

# Pinecone Vector Database (recommended with SQLite)
USE_PINECONE=true
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=keyword-ai-vectors
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSIONS=384
PINECONE_METRIC=cosine

# ============================================================
# 💳 Payment & Banking Configuration
# ============================================================

# Bank Transfer Details (for manual payments)
BANK_NAME=Your Bank Name
BANK_ACCOUNT_NAME=WebLift Inc.
BANK_ACCOUNT_NUMBER=XXXX-XXXX-XXXX-1234
BANK_IBAN=XX00 0000 0000 0000 0000 00
BANK_SWIFT=XXXXXXXX
BANK_BRANCH=Main Branch
BANK_COUNTRY=Your Country

# ============================================================
# 📧 Email Configuration (optional)
# ============================================================

# Email Backend (django.core.mail.backends.smtp.EmailBackend)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=WebLift <noreply@weblift.com>

# ============================================================
# 🌐 HTTP Client Configuration
# ============================================================

# User Agent for web requests
USER_AGENT=Mozilla/5.0 (compatible; WebLift-SEO/1.0)

# HTTP Timeouts (seconds)
HTTP_TIMEOUT=30
HTTP_CONNECT_TIMEOUT=10
HTTP_READ_TIMEOUT=20

# ============================================================
# 📊 Logging Configuration
# ============================================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log File Path (relative to project root)
LOG_FILE_PATH=logs/django.log

# ============================================================
# 🔧 Development Settings
# ============================================================

# Media Files Configuration
MEDIA_URL=/media/
MEDIA_ROOT=media/

# Static Files Configuration
STATIC_URL=/static/
STATIC_ROOT=staticfiles/

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=UTC
USE_I18N=true
USE_TZ=true

# ============================================================
# 📱 Subscription Configuration
# ============================================================

# Free Trial Settings
FREE_TRIAL_AUDITS=1
FREE_TRIAL_DAYS=7

# Subscription Limits
DEFAULT_MAX_AUDITS_MONTHLY=10
DEFAULT_MAX_KEYWORDS_ANALYSIS=50
DEFAULT_MAX_COMPETITORS_ANALYSIS=5

# ============================================================
# 🔒 Security Settings (Production)
# ============================================================

# SSL Verification Mode (strict/relaxed)
# strict = Full certificate verification (production default)
# relaxed = Allow self-signed certs (development only, DO NOT USE IN PRODUCTION)
SSL_VERIFY_MODE=strict

# Session Security
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# ============================================================
# 🎯 Feature Flags
# ============================================================

# Enable/Disable Features
ENABLE_COMPETITOR_ANALYSIS=true
ENABLE_AI_SUGGESTIONS=true
ENABLE_PDF_EXPORT=true
ENABLE_API_ACCESS=true
ENABLE_PRIORITY_SUPPORT=false

# ============================================================
# 📈 Analytics & Monitoring (optional)
# ============================================================

# Google Analytics
GOOGLE_ANALYTICS_ID=

# Sentry Error Tracking (Production)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1        # Performance tracing: 0.0 to 1.0
SENTRY_PROFILES_SAMPLE_RATE=0.1      # Profiling: 0.0 to 1.0
SENTRY_ENVIRONMENT=production          # production, staging, development
SENTRY_RELEASE=                        # Optional: Git commit hash or version

# ============================================================
# 🧪 Testing Configuration
# ============================================================

# Test Database
TEST_DATABASE_NAME=test_weblift

# Disable migrations during testing
TEST_DISABLE_MIGRATIONS=false

# ============================================================
# 📝 Notes & Instructions
# ============================================================

# 1. Required for basic functionality:
#    - DJANGO_SECRET_KEY
#    - USE_SQLITE=true (SQLite database)
#
# 2. For AI features:
#    - GROQ_API_KEY (recommended - free)
#    - or OPENAI_API_KEY / OPENROUTER_API_KEY
#
# 3. For vector storage (recommended with SQLite):
#    - PINECONE_API_KEY (create account at pinecone.io)
#    - Pinecone will be used for keyword embeddings and search
#
# 4. For SEO analysis:
#    - MOZ_ACCESS_ID & MOZ_SECRET_KEY (optional)
#    - PAGESPEED_API_KEY (optional)
#
# 5. For production:
#    - Set DEBUG=false
#    - Configure proper ALLOWED_HOSTS
#    - Set up Redis caching
#    - Configure S3 storage
#    - Set up email backend
#    - Configure security settings
#
# 6. For payments:
#    - Configure bank details for manual transfers
#
# SQLite + Pinecone Setup Benefits:
# ✅ No database server required
# ✅ Easy development and deployment
# ✅ Scalable vector search with Pinecone
# ✅ Automatic backups and maintenance
# ✅ Cost-effective for most use cases
#
# Generate secret key: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
